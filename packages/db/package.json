{
  "name": "@metriq/db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "kysely": "^0.28.5",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.5",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "typecheck": "tsc -p ./tsconfig.json",
    "migrate:latest": "tsx ./src/migrate.ts latest",
    "migrate:down": "tsx ./src/migrate.ts down",
    "seed": "tsx ./src/seed.ts"
  }
}

